<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Sanjay T — Full-Stack Developer</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
<style>
  :root {
    --bg: #0a0a0a;
    --bg2: #111111;
    --bg3: #181818;
    --amber: #f5a623;
    --amber-dim: #c47d0e;
    --amber-glow: rgba(245,166,35,0.12);
    --green: #4ade80;
    --cyan: #22d3ee;
    --text: #e8e0d0;
    --muted: #6b6560;
    --border: #2a2520;
    --card: #141414;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 14px;
    line-height: 1.7;
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    opacity: 0.028;
    pointer-events: none;
    z-index: 1000;
  }

  /* Nav */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.2rem 3rem;
    border-bottom: 1px solid var(--border);
    background: rgba(10,10,10,0.9);
    backdrop-filter: blur(16px);
  }
  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--amber);
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .nav-links { display: flex; gap: 2rem; list-style: none; }
  .nav-links a {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--amber); }
  .nav-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    color: var(--green);
    letter-spacing: 0.08em;
  }
  .status-dot {
    width: 6px; height: 6px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(74,222,128,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(74,222,128,0); }
  }

  /* Hero */
  #hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 3rem;
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(245,166,35,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(245,166,35,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black, transparent);
  }
  .hero-glow {
    position: absolute;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(245,166,35,0.06) 0%, transparent 70%);
    top: 50%; left: 40%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }
  .hero-content { position: relative; max-width: 900px; }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--amber);
    border: 1px solid var(--amber-dim);
    padding: 0.35rem 0.9rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.2s;
  }
  .hero-name {
    font-family: 'Syne', sans-serif;
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--text);
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.4s;
  }
  .hero-name span { color: var(--amber); }
  .hero-role {
    font-size: clamp(0.85rem, 1.5vw, 1.1rem);
    color: var(--muted);
    margin-top: 1.5rem;
    font-weight: 300;
    font-style: italic;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.6s;
  }
  .hero-desc {
    max-width: 540px;
    color: #7a7270;
    font-size: 0.82rem;
    margin-top: 1rem;
    line-height: 1.9;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.75s;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.9s;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.8rem;
    background: var(--amber);
    color: #0a0a0a;
    text-decoration: none;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .btn-primary:hover { background: #ffc04d; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(245,166,35,0.25); }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.8rem;
    border: 1px solid var(--border);
    color: var(--muted);
    text-decoration: none;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 0.2s;
  }
  .btn-outline:hover { border-color: var(--amber); color: var(--amber); transform: translateY(-2px); }
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 3rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 1.2s;
  }
  .scroll-line {
    width: 40px; height: 1px;
    background: var(--muted);
    animation: scrollLine 2s ease-in-out infinite;
  }
  @keyframes scrollLine {
    0% { width: 40px; } 50% { width: 70px; } 100% { width: 40px; }
  }

  /* Sections */
  section { padding: 7rem 3rem; }
  .section-label {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--amber);
    margin-bottom: 2.5rem;
  }
  .section-label::after {
    content: '';
    flex: 1;
    max-width: 60px;
    height: 1px;
    background: var(--amber-dim);
  }
  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--text);
    margin-bottom: 0.8rem;
  }

  /* About */
  #about { background: var(--bg2); }
  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 5rem;
    align-items: start;
    margin-top: 1.5rem;
  }
  .about-text { color: #938c86; font-size: 0.85rem; line-height: 2; }
  .about-text p + p { margin-top: 1.2rem; }
  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .stat-box {
    background: var(--card);
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: background 0.3s;
  }
  .stat-box:hover { background: #181410; }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--amber);
    line-height: 1;
  }
  .stat-label { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; line-height: 1.4; }

  /* Skills */
  #skills { background: var(--bg); }
  .skills-container { display: flex; flex-direction: column; gap: 1.8rem; margin-top: 1.5rem; }
  .skill-row {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 2rem;
    align-items: center;
    padding-bottom: 1.8rem;
    border-bottom: 1px solid var(--border);
  }
  .skill-cat { font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .skill-tag {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    font-size: 0.72rem;
    color: var(--text);
    transition: all 0.2s;
  }
  .skill-tag:hover { border-color: var(--amber); color: var(--amber); background: var(--amber-glow); }
  .skill-tag.featured { border-color: rgba(245,166,35,0.4); color: var(--amber); }

  /* Experience */
  #experience { background: var(--bg2); }
  .exp-timeline { position: relative; margin-top: 1.5rem; padding-left: 0; }
  .exp-item {
    position: relative;
    padding: 0 0 3.5rem 2.5rem;
    border-left: 1px solid var(--border);
  }
  .exp-item::before {
    content: '';
    position: absolute;
    left: -5px; top: 5px;
    width: 9px; height: 9px;
    background: var(--amber);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(245,166,35,0.5);
  }
  .exp-date { font-size: 0.62rem; letter-spacing: 0.12em; color: var(--amber); text-transform: uppercase; margin-bottom: 0.5rem; }
  .exp-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.2rem;
  }
  .exp-company { font-size: 0.75rem; color: var(--muted); margin-bottom: 1rem; }
  .exp-bullets { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .exp-bullets li { font-size: 0.78rem; color: #857f7b; padding-left: 1.2rem; position: relative; }
  .exp-bullets li::before { content: '→'; position: absolute; left: 0; color: var(--amber-dim); font-size: 0.7rem; }

  /* Projects */
  #projects { background: var(--bg); }
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1px; background: var(--border); margin-top: 1.5rem; }
  .project-card {
    background: var(--card);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .project-card::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    background: var(--amber);
    transform: scaleX(0);
    transition: transform 0.3s ease;
    transform-origin: left;
  }
  .project-card:hover::after { transform: scaleX(1); }
  .project-card:hover { background: #131109; }
  .project-num {
    font-family: 'Syne', sans-serif;
    font-size: 3rem;
    font-weight: 800;
    color: rgba(42,37,32,0.8);
    line-height: 1;
    margin-bottom: 1rem;
    transition: color 0.3s;
  }
  .project-card:hover .project-num { color: rgba(245,166,35,0.12); }
  .project-name {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.8rem;
  }
  .project-desc { font-size: 0.76rem; color: var(--muted); line-height: 1.9; margin-bottom: 1.5rem; }
  .project-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5rem; }
  .project-tag {
    font-size: 0.62rem;
    padding: 0.2rem 0.6rem;
    background: rgba(245,166,35,0.06);
    color: var(--amber-dim);
    letter-spacing: 0.08em;
    border: 1px solid rgba(245,166,35,0.15);
  }
  .project-link {
    font-size: 0.68rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color 0.2s;
  }
  .project-link:hover { color: var(--amber); }

  /* Education */
  #education { background: var(--bg2); }
  .edu-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1px; background: var(--border); margin-top: 1.5rem; }
  .edu-card { background: var(--card); padding: 2rem; transition: background 0.3s; }
  .edu-card:hover { background: #181410; }
  .edu-year { font-size: 0.62rem; color: var(--amber); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.8rem; }
  .edu-degree {
    font-family: 'Syne', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }
  .edu-school { font-size: 0.72rem; color: var(--muted); margin-bottom: 1rem; line-height: 1.5; }
  .edu-score {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--amber-dim);
    font-size: 0.68rem;
    color: var(--amber);
    letter-spacing: 0.08em;
  }

  /* Certifications */
  #certs { background: var(--bg); }
  .certs-list { margin-top: 1.5rem; }
  .cert-item {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--border);
    transition: padding-left 0.3s, color 0.3s;
  }
  .cert-item:hover { padding-left: 0.8rem; color: var(--text); }
  .cert-icon { color: var(--amber); font-size: 0.9rem; flex-shrink: 0; }
  .cert-text { font-size: 0.8rem; color: #8a8480; transition: color 0.3s; }
  .cert-item:hover .cert-text { color: var(--text); }

  /* Contact */
  #contact { background: var(--bg2); }
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
    margin-top: 1.5rem;
  }
  .contact-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.9; margin-bottom: 2rem; }
  .contact-links { display: flex; flex-direction: column; gap: 0.6rem; }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: var(--muted);
    font-size: 0.78rem;
    transition: all 0.2s;
    padding: 0.9rem 1rem;
    border: 1px solid transparent;
  }
  .contact-link:hover { color: var(--amber); border-color: var(--border); background: var(--amber-glow); padding-left: 1.4rem; }
  .contact-link-icon { color: var(--amber); font-size: 0.85rem; width: 20px; text-align: center; flex-shrink: 0; }
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .contact-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .contact-field label { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
  .contact-field input,
  .contact-field textarea {
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: 'DM Mono', monospace;
    font-size: 0.8rem;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    resize: none;
  }
  .contact-field input:focus,
  .contact-field textarea:focus { border-color: var(--amber); background: #0f0e0b; }
  .contact-field textarea { height: 110px; }

  footer {
    padding: 2rem 3rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    background: var(--bg);
  }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.65s ease, transform 0.65s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    #hero, section { padding-left: 1.5rem; padding-right: 1.5rem; }
    .about-grid, .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .hero-scroll { left: 1.5rem; }
    .skill-row { grid-template-columns: 1fr; gap: 0.8rem; }
    footer { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
</head>
